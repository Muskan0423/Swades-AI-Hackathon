# ==============================================
# Recording Pipeline Server Configuration
# ==============================================
# Copy this file to .env and update values

# Database (Required)
DATABASE_URL="postgresql://postgres:password@localhost:5432/recordings"

# CORS (Required)
CORS_ORIGIN="http://localhost:3001"

# Environment
NODE_ENV="development"

# ==============================================
# Storage Configuration
# ==============================================

# S3-Compatible Storage (MinIO/AWS S3)
STORAGE_BUCKET_NAME="recordings"
STORAGE_ENDPOINT="http://localhost:9000"    # MinIO (remove for AWS S3)
STORAGE_ACCESS_KEY="minioadmin"
STORAGE_SECRET_KEY="minioadmin123"
STORAGE_REGION="us-east-1"

# Local Storage Fallback
STORAGE_LOCAL_PATH="./uploads"

# ==============================================
# Redis Cache (Optional but Recommended)
# ==============================================
REDIS_URL="redis://localhost:6379"

# ==============================================
# CDN Configuration (Optional)
# ==============================================
# CDN_URL="https://d123456789.cloudfront.net"

# ==============================================
# Rate Limiting
# ==============================================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# ==============================================
# API Authentication (Optional)
# ==============================================
# API_KEY="your-secret-api-key"

# ==============================================
# OpenAI Whisper Transcription (Optional)
# ==============================================
# Get your API key at: https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-your-openai-api-key"
